#
# `direnv` environment for jj-dev. Loaded automatically when entering the project directory.
#
# ─── USAGE ────────────────────────────────────────────────────────────────────────────────────────────────────────────
#
# direnv allow  # run once after any change to re-activate
#
# ─── SEE ──────────────────────────────────────────────────────────────────────────────────────────────────────────────
#
# • https://direnv.net
#
# ██████████████████████████████████████████████████████████████████████████████████████████████████████████████████████

# Helper method to load NVM
use_nvm() {
  local node_version
  node_version=$(cat .nvmrc 2>/dev/null)
  if [ -n "$node_version" ]; then
    echo "nvm: using Node $node_version"
    export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
    # shellcheck disable=SC1091
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    nvm use "$node_version" --silent
  fi
}
use_nvm

# ─── Environment ──────────────────────────────────────────────────────────────
# Base environment defaults; overridable via .env for local secrets.
export NODE_ENV="${NODE_ENV:-development}"
export APP_ENV="${APP_ENV:-local}"

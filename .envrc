# ─── .envrc ──────────────────────────────────────────────────────────────────
# direnv environment for jj-dev. Loaded automatically when entering the project
# directory. Run `direnv allow` after any changes to re-activate.
#
# DO NOT commit secrets here — use .env for local secrets (gitignored).
# Only non-secret, environment-shape config belongs in this file.
#
# See: https://direnv.net

# ─── Node version ─────────────────────────────────────────────────────────────
# Reads .nvmrc and activates the pinned Node version via nvm. Ensures all
# contributors run the same runtime without having to call `nvm use` manually.
use_nvm() {
  local node_version
  node_version=$(cat .nvmrc 2>/dev/null)
  if [ -n "$node_version" ]; then
    echo "nvm: using Node $node_version"
    export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
    # shellcheck disable=SC1091
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    nvm use "$node_version" --silent
  fi
}
use_nvm

# ─── Environment ──────────────────────────────────────────────────────────────
# Base environment defaults — overridable via .env for local secrets.
export NODE_ENV="${NODE_ENV:-development}"
export APP_ENV="${APP_ENV:-local}"

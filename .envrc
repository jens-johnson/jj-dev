## ─── jj-dev environment ────────────────────────────────────────────────────
## Loaded automatically by direnv. Run `direnv allow` after any changes.
##
## DO NOT commit secrets here. Use .env for local secrets (gitignored).
## This file is committed — only put non-secret config here.

## Node version (via nvm)
use_nvm() {
  local node_version
  node_version=$(cat .nvmrc 2>/dev/null)
  if [ -n "$node_version" ]; then
    echo "nvm: using Node $node_version"
    export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
    # shellcheck disable=SC1091
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    nvm use "$node_version" --silent
  fi
}
use_nvm

## Environment
export NODE_ENV="${NODE_ENV:-development}"
export APP_ENV="${APP_ENV:-local}"

#
# Git hook: runs lint and type-check before every git push. Aborts if either check fails.
#
# ─── USAGE ─────────────────────────────────────────────────────────────────────────────────────────────────────────────
#
# Runs automatically on `git push`. Exits 1 on any ESLint or TypeScript error.
#
# █████████████████████████████████████████████████████████████████████████████████████████████████████████████████████
echo "→ Running lint..."
npm run lint || exit 1

# Type-check — exits 1 on any TypeScript error, which aborts the push.
echo "→ Running typecheck..."
npm run typecheck || exit 1

echo "✓ All checks passed"

# █████████████████████████████████████████████████████████████████████████████████████████████████████████████████████
#
#                                ██        ██                     ▄▄
#                                ▀▀        ▀▀                     ██
#                              ████      ████                ▄███▄██   ▄████▄   ██▄  ▄██
#                                ██        ██               ██▀  ▀██  ██▄▄▄▄██   ██  ██
#                                ██        ██      █████    ██    ██  ██▀▀▀▀▀▀   ▀█▄▄█▀
#                                ██        ██               ▀██▄▄███  ▀██▄▄▄▄█    ████
#                                ██        ██                 ▀▀▀ ▀▀    ▀▀▀▀▀      ▀▀
#                             ████▀     ████▀
#
# █████████████████████████████████████████████████████████████████████████████████████████████████████████████████████
# ███████████████████████████████████████████████████ .env.example ████████████████████████████████████████████████████
#
# Environment variable reference for jj-dev. Copy to .env and fill in values for local development.
#
# ─── USAGE ─────────────────────────────────────────────────────────────────────────────────────────────────────────────
#
# cp .env.example .env
# # Then edit .env with real values. Never commit .env — it is gitignored.
#
# █████████████████████████████████████████████████████████████████████████████████████████████████████████████████████
NODE_ENV=development
APP_ENV=local

# MongoDB (Phase 2+)
# MONGODB_URI=mongodb+srv://...

# Analytics (Phase 3+)
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Strava API ────────────────────────────────────────────────────────────────────────────────────────────────────────
# Used by the /api/strava server route to fetch activity data for the about page metrics card.
# Never expose these on the client — all Strava requests go through the Nuxt server layer.
#
# How to get these:
#   1. Create/find your app at https://www.strava.com/settings/api
#   2. Client ID and Secret are shown on that page
#   3. For the refresh token, do a one-time OAuth exchange:
#      → https://www.strava.com/oauth/authorize?client_id=YOUR_ID&response_type=code&redirect_uri=http://localhost&approval_prompt=force&scope=read,activity:read
#      → Grab the `code` param from the redirect URL, then POST to:
#      → https://www.strava.com/oauth/token with client_id, client_secret, code, grant_type=authorization_code
#      → Save the `refresh_token` from the response — it doesn't expire.
#
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# ─── Auth — Google OIDC (nuxt-auth-utils) ────────────────────────────────────────────────────────────────────────────
# Powers the Sign in button in the nav. The /auth/callback server route runs the OAuth exchange and seals an encrypted
# session cookie. Credentials are server-only — never exposed to the client.
#
# How to get these:
#   1. Google Cloud console → APIs & Services → Credentials → create an OAuth 2.0 Client ID (Web application).
#   2. Add authorized redirect URIs: http://localhost:3000/auth/callback (local) plus the staging/prod callback URLs.
#   3. Copy the Client ID and Client Secret below. In Vercel these are stored as GOOGLE_OAUTH_CLIENT_ID / _SECRET.
#
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Secret used to seal the session cookie — must be at least 32 characters. In dev, nuxt-auth-utils auto-generates one
# and appends it here if missing; in staging/prod you MUST set it explicitly (e.g. `openssl rand -base64 32`).
NUXT_SESSION_PASSWORD=

# Email granted admin-level access once authenticated. Optional — defaults to christopher.jens.johnson@gmail.com.
# ADMIN_EMAIL=

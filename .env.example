# ─── .env.example ────────────────────────────────────────────────────────────
# Environment variable reference for jj-dev. Copy to .env and fill in values
# for local development. .env is gitignored — never commit real secrets.

NODE_ENV=development
APP_ENV=local

# MongoDB (Phase 2+)
# MONGODB_URI=mongodb+srv://...

# Analytics (Phase 3+)
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
